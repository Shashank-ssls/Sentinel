# Copy to .env and fill in. Never commit .env.

# Path to the serialized best model (set after Phase 2)
MODEL_PATH=models/best_model.pkl

# SQLite cache for external lookups (WHOIS/cert/etc.)
CACHE_DB=data/cache.db

# Random seed for reproducible splits/training
RANDOM_SEED=42

# Optional — only if you later add an LLM-assisted step (not needed for v1)
# LLM_API_KEY=
